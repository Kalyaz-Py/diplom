<Window x:Class="diplom.Views.TeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Окно преподавателя" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtGreeting" FontSize="16" FontWeight="Bold" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
            <TextBlock VerticalAlignment="Center" Text="Дисциплина:" Margin="0,0,8,0" />
            <ComboBox x:Name="CbDisciplines" Width="300" DisplayMemberPath="DisciplineName" SelectedValuePath="DisciplineID" Style="{StaticResource ModernComboBox}" SelectionChanged="CbDisciplines_SelectionChanged" />
            <Button x:Name="BtnRefresh" Content="Обновить" Margin="8,0,0,0" Click="BtnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" MinHeight="36" Padding="8" />
        </StackPanel>

        <DataGrid x:Name="DgDebts" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Style="{StaticResource ModernDataGrid}" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер зачетки" Binding="{Binding StudentCardNumber}" Width="150" />
                <DataGridTextColumn Header="Студент" Binding="{Binding StudentName}" Width="2*" />
                <DataGridTextColumn Header="Дисциплина" Binding="{Binding DisciplineName}" Width="1.5*" />
                <DataGridTextColumn Header="Статус" Binding="{Binding DebtStatus}" Width="100" />
                <DataGridTextColumn Header="Дата записи" Binding="{Binding DateRecorded}" Width="140" />
                <DataGridCheckBoxColumn Header="Сдано" Binding="{Binding IsCleared, Mode=OneWay}" Width="80" IsReadOnly="True" />
                <!-- Оценка не используется -->
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnMarkCleared" Content="Отметить сданным" Click="BtnMarkCleared_Click" Margin="0,0,8,0" Style="{StaticResource SuccessButtonStyle}" MinHeight="36" Padding="8" />
            <Button x:Name="BtnExit" Content="Выход" Click="BtnExit_Click" Style="{StaticResource SecondaryButtonStyle}" MinHeight="36" Padding="8" />
        </StackPanel>
    </Grid>
</Window>
